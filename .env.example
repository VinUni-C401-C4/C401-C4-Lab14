# ─── API Keys ───────────────────────────────────────────────────────────────
# Required for LLM-based Judge and RAGAS metrics.
# If not set, the system falls back to rule-based evaluation automatically.

OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Anthropic API key if using Claude as a second Judge model
# ANTHROPIC_API_KEY=sk-ant-your-key-here
